# Airtable Configuration
# Get your API key at https://airtable.com/create/tokens
AIRTABLE_API_KEY=your_airtable_personal_access_token
# Found in the URL when viewing your base: airtable.com/appXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
# Table ID from the Airtable URL (tblXXXXXXXXXXXXXX) or table name — Timesheets
AIRTABLE_TABLE_NAME=tblXXXXXXXXXXXXXX
# Table ID for the Name Conversions table
AIRTABLE_CV_TABLE_ID=tblXXXXXXXXXXXXXX

# ISP Monitoring
ISP_PROVIDER_NAME=Comcast
ISP_CHECK_INTERVAL=300000
TARGET_URL=https://8.8.8.8
GATEWAY_IP=your_gateway_ip
